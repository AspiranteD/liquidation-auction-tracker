# --- Monitoring ---
# Comma-separated B-Stock country codes to scrape (ES, IT, DE, FR, ...)
MONITOR_COUNTRIES=ES

# Where the SQLite DB and downloaded manifests live
DB_PATH=data/auctions.db
MANIFEST_DIR=data/manifests

# --- Bid model: recovery-based, NOT fixed percentages ---
# The recommended bid makes the landed cost equal recovery / ALERT_BID_MULTIPLE
# of retail, where recovery (real revenue / B-Stock retail) comes from the macro
# sales study persisted in data/recovery.json (scripts/build_recovery.py). A lot
# fails the price filter when its current bid exceeds that recommended bid.
ALERT_BID_MULTIPLE=3.0
# A lot is a "very good" last-call when the current bid is at or below this
# fraction of the recommended bid (lots of headroom left).
ALERT_VERY_GOOD_HEADROOM=0.5

# Minimum retail value (EUR) per lot family; families not listed never alert
ALERT_MIN_RETAIL_4_PALLETS=20000
ALERT_MIN_RETAIL_SMALL_TRUCKLOAD=50000
ALERT_MIN_RETAIL_TRUCKLOAD=100000

# Title keywords that mark a lot as electronics (informational only now)
ELECTRONICS_KEYWORDS=Wireless,PC Goods,Camera,Computers,Electronics,Home Entertainment

# Alerts fire as a reminder ladder before the auction closes (not when it
# appears): one WhatsApp/email per stage, minutes-to-close thresholds
REMINDER_STAGES=30,15,10,5
# At this many minutes (or less) to close, escalate with a voice call too
CALL_AT_MINUTES=5

# --- Voice-call escalation via CallMeBot Telegram call (optional) ---
# Setup: install Telegram and send /start to @CallMeBot_txtbot, then set
# your Telegram username here. The call rings on Telegram and a TTS voice
# reads the alert. Docs: https://www.callmebot.com/blog/telegram-call-api/
CALL_ALERTS_ENABLED=false
CALLMEBOT_TELEGRAM_USER=@your_telegram_user
CALL_LANG=es-ES-Standard-A
CALL_REPEAT=2

# Minimum piece count to consider (0 = no minimum)
ALERT_MIN_PIECES=0

# --- WhatsApp alerts via CallMeBot (optional) ---
# Setup: https://www.callmebot.com/blog/free-api-whatsapp-messages/
# 1. Add the CallMeBot number to your WhatsApp contacts
# 2. Send it: "I allow callmebot to send me messages"
# 3. It replies with your personal apikey
WHATSAPP_ALERTS_ENABLED=false
CALLMEBOT_PHONE=+34600111222
CALLMEBOT_APIKEY=your_apikey

# --- Email alerts (optional) ---
EMAIL_ALERTS_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
# For Gmail use an App Password (https://myaccount.google.com/apppasswords)
SMTP_PASSWORD=your_app_password
EMAIL_SENDER=your_email@gmail.com
EMAIL_RECIPIENTS=alerts@example.com,me@example.com
